post_install() {
  printf '%s\n' \
    'Configure ~/.config/sayall/config.json, then run:' \
    '  sayall setup' \
    'Add your compositor key binding for: sayall toggle'
}

post_upgrade() {
  printf '%s\n' \
    "If upgrading outside 'sayall update', restart SayAll with:" \
    '  sayall setup'
}
